+def _compare_metric_rows(
+    benchmark: str,
+    baseline_summary: dict[str, Any],
+    candidate_summary: dict[str, Any],
+    baseline_label: str,
+    candidate_label: str,
+) -> list[dict[str, Any]]:
+    rows = []
+    for metric_name, direction in benchmark_primary_metrics(benchmark):
+        baseline_value = baseline_summary.get(metric_name)
+        candidate_value = candidate_summary.get(metric_name)
+        rows.append(
+            {
+                "benchmark": benchmark,
+                "metric": metric_name,
+                "direction": direction,
+                "baseline_label": baseline_label,
+                "baseline_value": baseline_value,
+                "candidate_label": candidate_label,
+                "candidate_value": candidate_value,
+                "winner": choose_winner(baseline_value, candidate_value, direction),
+            }
+        )
+    return rows
+
