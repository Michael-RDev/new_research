+                sys.executable,
+                "-m",
+                "omnivoice.eval.wer.minimax",
+                "--wav-path",
+                str(wavs_dir),
+                "--test-list",
+                str(_benchmark_test_list(spec, eval_data_dir)),
+                "--decode-path",
+                str(logs_dir / "wer.log"),
+                "--model-dir",
+                str(eval_model_dir),
+                "--nj-per-gpu",
+                str(args.metric_nj_per_gpu),
+            ]
+        else:
+            wer_cmd = [
+                args.fleurs_python,
+                str(repo_root / "omnivoice" / "eval" / "wer" / "fleurs.py"),
+                "--wav-path",
+                str(wavs_dir),
+                "--test-list",
+                str(_benchmark_test_list(spec, eval_data_dir)),
+                "--decode-path",
+                str(logs_dir / "wer.log"),
+                "--model-card",
+                str(args.fleurs_model_card),
+                "--chunk-size",
+                str(args.fleurs_chunk_size),
+                "--batch-size",
+                str(args.fleurs_batch_size),
+                "--nj-per-gpu",
+                str(args.metric_nj_per_gpu),
+            ]
+        _run_command(wer_cmd, cwd=repo_root, env=env)
+
+        if spec.has_utmos:
+            _run_command(
+                [
+                    sys.executable,
+                    "-m",
+                    "omnivoice.eval.mos.utmos",
+                    "--wav-path",
+                    str(wavs_dir),
+                    "--test-list",
+                    str(_benchmark_test_list(spec, eval_data_dir)),
+                    "--decode-path",
+                    str(logs_dir / "utmos.log"),
+                    "--model-dir",
+                    str(eval_model_dir),
+                    "--nj-per-gpu",
+                    str(args.metric_nj_per_gpu),
+                ],
+                cwd=repo_root,
+                env=env,
+            )
+
+    return _parse_standard_summary(spec, benchmark_dir)
+
+
+def _run_cloneval(
+    repo_root: Path,
+    env: dict[str, str],
+    model_label: str,
+    model_path: str,
+    cloneval_module: str,
+    output_dir: Path,
+    args: argparse.Namespace,
+) -> dict[str, Any]:
+    cloneval_dir = _model_dir(output_dir, model_label) / "cloneval"
+    summary_path = cloneval_dir / "summary.json"
+    if args.skip_existing and summary_path.exists():
+        return json.loads(summary_path.read_text(encoding="utf-8"))
+
+    if not args.render_only:
+        cloneval_test_list = Path(args.cloneval_test_list)
+        if not cloneval_test_list.is_absolute():
+            cloneval_test_list = (repo_root / cloneval_test_list).resolve()
+        cloneval_repo = Path(args.cloneval_repo)
+        if not cloneval_repo.is_absolute():
+            cloneval_repo = (repo_root / cloneval_repo).resolve()
+        cmd = [
+            sys.executable,
+            "-m",
+            cloneval_module,
+            "--model",
+            model_path,
+            "--test_list",
+            str(cloneval_test_list),
+            "--work_dir",
+            str(cloneval_dir),
+            "--cloneval_repo",
+            str(cloneval_repo),
+            "--num_step",
+            str(args.num_step),
+            "--guidance_scale",
+            str(args.guidance_scale),
+            "--t_shift",
+            str(args.t_shift),
+            "--device_map",
+            str(args.cloneval_device_map),
+            "--dtype",
+            str(args.cloneval_dtype),
+        ]
+        if args.cloneval_emotion_transfer:
+            cmd.append("--evaluate_emotion_transfer")
+        _run_command(cmd, cwd=repo_root, env=env)
+
+    summary = summarize_cloneval_metrics(cloneval_dir / "metrics")
+    summary["benchmark"] = "cloneval"
+    summary["artifacts"] = {
+        "benchmark_dir": str(cloneval_dir),
+        "metrics_dir": str(cloneval_dir / "metrics"),
+    }
+    _write_json(summary_path, summary)
+    return summary
+
+
+def _scorecard(metric_rows: list[dict[str, Any]]) -> dict[str, int]:
+    scorecard = {
+        "baseline_wins": 0,
+        "candidate_wins": 0,
+        "ties": 0,
+        "unscored": 0,
+    }
+    for row in metric_rows:
+        winner = row["winner"]
+        if winner == "baseline":
+            scorecard["baseline_wins"] += 1
+        elif winner == "candidate":
+            scorecard["candidate_wins"] += 1
+        elif winner == "tie":
+            scorecard["ties"] += 1
+        else:
+            scorecard["unscored"] += 1
+    return scorecard
+
+
+def main() -> None:
+    parser = get_parser()
+    args = parser.parse_args()
+
+    logging.basicConfig(
+        format="%(asctime)s %(levelname)s [%(filename)s:%(lineno)d] %(message)s",
+        level=logging.INFO,
+        force=True,
+    )
+
+    repo_root = Path(__file__).resolve().parents[2]
+    output_dir = (repo_root / args.output_dir).resolve()
+    eval_data_dir = (repo_root / args.eval_data_dir).resolve()
+    eval_model_dir = (repo_root / args.eval_model_dir).resolve()
+    env = _repo_env(repo_root)
+
+    if args.prepare_assets and not args.render_only:
+        prepare_eval_assets(repo_root, eval_data_dir, eval_model_dir, env)
+
+    baseline_summaries = {}
+    candidate_summaries = {}
+    standard_rows = []
+
+    for benchmark in args.benchmarks:
+        spec = BENCHMARK_SPECS[benchmark]
+        baseline_summary = _run_standard_benchmark(
+            repo_root=repo_root,
+            env=env,
+            model_label=args.baseline_label,
+            model_path=args.baseline_model,
+            infer_module=args.baseline_infer_module,
+            spec=spec,
+            output_dir=output_dir,
+            eval_data_dir=eval_data_dir,
+            eval_model_dir=eval_model_dir,
+            args=args,
+        )
+        candidate_summary = _run_standard_benchmark(
+            repo_root=repo_root,
+            env=env,
+            model_label=args.candidate_label,
+            model_path=args.candidate_model,
+            infer_module=args.candidate_infer_module,
+            spec=spec,
+            output_dir=output_dir,
+            eval_data_dir=eval_data_dir,
+            eval_model_dir=eval_model_dir,
+            args=args,
+        )
+        baseline_summaries[benchmark] = baseline_summary
+        candidate_summaries[benchmark] = candidate_summary
+        standard_rows.append(
+            _standard_summary_row(args.baseline_label, benchmark, baseline_summary)
+        )
+        standard_rows.append(
+            _standard_summary_row(args.candidate_label, benchmark, candidate_summary)
+        )
+
+    cloneval_rows = []
+    metric_rows = []
+    for benchmark in args.benchmarks:
+        metric_rows.extend(
+            _compare_metric_rows(
+                benchmark=benchmark,
+                baseline_summary=baseline_summaries[benchmark],
+                candidate_summary=candidate_summaries[benchmark],
+                baseline_label=args.baseline_label,
+                candidate_label=args.candidate_label,
+            )
+        )
+
+    if args.cloneval_test_list:
+        baseline_cloneval = _run_cloneval(
+            repo_root=repo_root,
+            env=env,
+            model_label=args.baseline_label,
+            model_path=args.baseline_model,
+            cloneval_module=args.baseline_cloneval_module,
+            output_dir=output_dir,
+            args=args,
+        )
+        candidate_cloneval = _run_cloneval(
+            repo_root=repo_root,
+            env=env,
+            model_label=args.candidate_label,
+            model_path=args.candidate_model,
+            cloneval_module=args.candidate_cloneval_module,
+            output_dir=output_dir,
+            args=args,
+        )
+        baseline_cloneval["label"] = args.baseline_label
+        candidate_cloneval["label"] = args.candidate_label
+        cloneval_rows = [baseline_cloneval, candidate_cloneval]
+        metric_rows.extend(
+            _compare_metric_rows(
+                benchmark="cloneval",
+                baseline_summary=baseline_cloneval,
+                candidate_summary=candidate_cloneval,
+                baseline_label=args.baseline_label,
+                candidate_label=args.candidate_label,
+            )
+        )
+
+    scorecard = _scorecard(metric_rows)
+    settings = {
+        "baseline_model": args.baseline_model,
+        "candidate_model": args.candidate_model,
+        "num_step": args.num_step,
+        "guidance_scale": args.guidance_scale,
+        "t_shift": args.t_shift,
+        "batch_duration": args.batch_duration,
+        "primary_metric_scorecard": scorecard,
+    }
+
+    comparison_dir = output_dir / "comparison"
+    comparison_dir.mkdir(parents=True, exist_ok=True)
+
+    summary_json = {
+        "settings": settings,
+        "standard_benchmarks": {
+            benchmark: {
+                args.baseline_label: baseline_summaries[benchmark],
+                args.candidate_label: candidate_summaries[benchmark],
+            }
+            for benchmark in args.benchmarks
+        },
+        "cloneval": {
+            args.baseline_label: cloneval_rows[0] if cloneval_rows else None,
+            args.candidate_label: cloneval_rows[1] if len(cloneval_rows) > 1 else None,
+        },
+        "primary_metric_rows": metric_rows,
+    }
+    _write_json(comparison_dir / "benchmark_summary.json", summary_json)
+
+    csv_rows = []
+    for row in standard_rows:
+        csv_rows.append(
+            {
+                "benchmark": row["benchmark"],
+                "label": row["label"],
+                "wer_selected": row.get("wer_selected"),
+                "sim_selected": row.get("sim_selected"),
+                "utmos_selected": row.get("utmos_selected"),
+                "mean_real_time_factor": row.get("mean_real_time_factor"),
+                "max_rss_bytes": row.get("max_rss_bytes"),
+            }
+        )
+    for row in cloneval_rows:
+        csv_rows.append(
+            {
+                "benchmark": "cloneval",
+                "label": row["label"],
+                "wer_selected": None,
+                "sim_selected": None,
+                "utmos_selected": None,
+                "speaker_similarity": row.get("speaker_similarity"),
+                "intelligibility": row.get("intelligibility"),
+                "naturalness": row.get("naturalness"),
+                "emotion_transfer": row.get("emotion_transfer"),
+                "mean_real_time_factor": row.get("mean_real_time_factor"),
+                "max_rss_bytes": row.get("max_rss_bytes"),
+            }
+        )
+    _write_csv(
+        comparison_dir / "benchmark_summary.csv",
+        csv_rows,
+        fieldnames=[
+            "benchmark",
+            "label",
+            "wer_selected",
+            "sim_selected",
+            "utmos_selected",
+            "speaker_similarity",
+            "intelligibility",
+            "naturalness",
+            "emotion_transfer",
+            "mean_real_time_factor",
+            "max_rss_bytes",
+        ],
+    )
+    _write_csv(
+        comparison_dir / "primary_metric_scorecard.csv",
+        metric_rows,
+        fieldnames=[
+            "benchmark",
+            "metric",
+            "direction",
+            "baseline_label",
+            "baseline_value",
+            "candidate_label",
+            "candidate_value",
+            "winner",
+        ],
+    )
+
+    report = _render_report(
+        settings=settings,
+        standard_rows=standard_rows,
+        cloneval_rows=cloneval_rows,
+        baseline_label=args.baseline_label,
+        candidate_label=args.candidate_label,
+    )
+    (comparison_dir / "report.md").write_text(report, encoding="utf-8")
+    logging.info("Wrote comparison artifacts to %s", comparison_dir)
+
+
+if __name__ == "__main__":
+    main()
