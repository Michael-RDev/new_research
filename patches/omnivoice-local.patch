+    )
+    parser.add_argument(
+        "--cloneval-repo",
+        type=str,
+        default="../cloneval",
+        help="Path to the official CloneEval repository.",
+    )
+    parser.add_argument(
+        "--baseline-cloneval-module",
+        type=str,
+        default="omnivoice.eval.cloneval_benchmark",
+        help="Python module used to run baseline CloneEval generation.",
+    )
+    parser.add_argument(
+        "--candidate-cloneval-module",
+        type=str,
+        default="omnivoice.eval.cloneval_benchmark",
+        help="Python module used to run candidate CloneEval generation.",
+    )
+    parser.add_argument(
+        "--cloneval-device-map",
+        type=str,
+        default=_default_cloneval_device(),
+        help="Device map for CloneEval inference.",
+    )
+    parser.add_argument(
+        "--cloneval-dtype",
+        type=str,
+        default="float16" if torch.cuda.is_available() else "float32",
+        help="Torch dtype for CloneEval inference.",
+    )
+    parser.add_argument(
+        "--cloneval-emotion-transfer",
+        action="store_true",
+        help="Enable CloneEval emotion-transfer scoring when supported.",
+    )
+    parser.add_argument(
+        "--output-dir",
+        type=str,
+        default="exp/benchmark_compare",
+        help="Root directory for comparison artifacts.",
+    )
+    parser.add_argument(
+        "--eval-data-dir",
+        type=str,
+        default="download/tts_eval_datasets",
+        help="Directory containing the benchmark JSONLs and extracted audio.",
+    )
+    parser.add_argument(
+        "--eval-model-dir",
+        type=str,
+        default="download/tts_eval_models",
+        help="Directory containing evaluation models.",
+    )
+    parser.add_argument(
+        "--prepare-assets",
+        action="store_true",
+        help="Download standard benchmark datasets/models before evaluation.",
+    )
+    parser.add_argument(
+        "--render-only",
+        action="store_true",
+        help="Skip command execution and only render summaries from existing outputs.",
+    )
+    parser.add_argument(
+        "--skip-existing",
+        action="store_true",
+        help="Reuse completed benchmark outputs when summary files already exist.",
+    )
+    parser.add_argument(
+        "--num-step",
+        type=int,
+        default=32,
+        help="Iterative decoding steps shared by both models.",
+    )
+    parser.add_argument(
+        "--guidance-scale",
+        type=float,
+        default=2.0,
+        help="Classifier-free guidance scale shared by both models.",
+    )
+    parser.add_argument(
+        "--t-shift",
+        type=float,
+        default=0.1,
+        help="Inference time-shift shared by both models.",
+    )
+    parser.add_argument(
+        "--infer-nj-per-gpu",
+        type=int,
+        default=1,
+        help="Number of inference workers per GPU for batch generation.",
+    )
+    parser.add_argument(
+        "--metric-nj-per-gpu",
+        type=int,
+        default=1,
+        help="Number of metric workers per GPU for SIM/UTMOS/WER scripts.",
+    )
+    parser.add_argument(
+        "--batch-duration",
+        type=float,
+        default=600.0,
+        help="Inference batch duration budget shared by both models.",
+    )
+    parser.add_argument(
+        "--batch-size",
+        type=int,
+        default=0,
+        help="Optional fixed inference batch size. Overrides duration batching when > 0.",
+    )
+    parser.add_argument(
+        "--preprocess-prompt",
+        action=argparse.BooleanOptionalAction,
+        default=False,
+        help="Whether to preprocess reference prompts during inference.",
+    )
+    parser.add_argument(
+        "--postprocess-output",
+        action=argparse.BooleanOptionalAction,
+        default=False,
+        help="Whether to post-process generated output audio.",
+    )
+    parser.add_argument(
+        "--audio-chunk-threshold",
+        type=float,
+        default=1000.0,
+        help="Audio chunk split threshold passed to batch inference.",
+    )
+    parser.add_argument(
+        "--audio-chunk-duration",
+        type=float,
+        default=15.0,
+        help="Maximum chunk duration for long prompts.",
+    )
+    parser.add_argument(
+        "--denoise",
