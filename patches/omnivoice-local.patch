+        ),
+        "",
+        "## Standard Benchmarks",
+        "",
+        "| Benchmark | Model | WER/CER | SIM-o | UTMOS | Mean RTF | Peak RSS (bytes) |",
+        "| --- | --- | ---: | ---: | ---: | ---: | ---: |",
+    ]
+
+    for row in standard_rows:
+        lines.append(
+            "| {benchmark} | {label} | {wer} | {sim} | {utmos} | {rtf} | {rss} |".format(
+                benchmark=row["benchmark"],
+                label=row["label"],
+                wer=format_metric(row.get("wer_selected"), 2),
+                sim=format_metric(row.get("sim_selected"), 4),
+                utmos=format_metric(row.get("utmos_selected"), 2),
+                rtf=format_metric(row.get("mean_real_time_factor"), 4),
+                rss=_format_rss(row.get("max_rss_bytes")),
+            )
+        )
+
+    if cloneval_rows:
+        lines.extend(
+            [
+                "",
+                "## CloneEval",
+                "",
+                "| Model | Speaker Similarity | Intelligibility | Naturalness | Emotion Transfer | Mean RTF | Peak RSS (bytes) |",
+                "| --- | ---: | ---: | ---: | ---: | ---: | ---: |",
+            ]
+        )
+        for row in cloneval_rows:
+            lines.append(
+                "| {label} | {speaker_similarity} | {intelligibility} | {naturalness} | {emotion_transfer} | {rtf} | {rss} |".format(
+                    label=row["label"],
+                    speaker_similarity=format_metric(
+                        row.get("speaker_similarity"), 4
+                    ),
+                    intelligibility=format_metric(
+                        row.get("intelligibility"), 4
+                    ),
+                    naturalness=format_metric(row.get("naturalness"), 4),
+                    emotion_transfer=format_metric(
+                        row.get("emotion_transfer"), 4
+                    ),
+                    rtf=format_metric(row.get("mean_real_time_factor"), 4),
+                    rss=_format_rss(row.get("max_rss_bytes")),
+                )
+            )
+
+    scorecard = settings["primary_metric_scorecard"]
+    lines.extend(
