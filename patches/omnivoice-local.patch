+        _run_command(cmd, cwd=repo_root, env=env)
+
+    summary = summarize_cloneval_metrics(cloneval_dir / "metrics")
+    summary["benchmark"] = "cloneval"
+    summary["artifacts"] = {
+        "benchmark_dir": str(cloneval_dir),
+        "metrics_dir": str(cloneval_dir / "metrics"),
+    }
+    _write_json(summary_path, summary)
+    return summary
+
+
+def _scorecard(metric_rows: list[dict[str, Any]]) -> dict[str, int]:
+    scorecard = {
+        "baseline_wins": 0,
+        "candidate_wins": 0,
+        "ties": 0,
+        "unscored": 0,
+    }
+    for row in metric_rows:
+        winner = row["winner"]
+        if winner == "baseline":
+            scorecard["baseline_wins"] += 1
+        elif winner == "candidate":
+            scorecard["candidate_wins"] += 1
+        elif winner == "tie":
+            scorecard["ties"] += 1
+        else:
+            scorecard["unscored"] += 1
+    return scorecard
+
