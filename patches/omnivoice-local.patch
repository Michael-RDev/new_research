+from omnivoice.eval.benchmark_summary import (
+    benchmark_primary_metrics,
+    choose_winner,
+    format_metric,
+    parse_hubert_wer_log,
+    parse_multilingual_wer_log,
+    parse_runtime_summary,
+    parse_seedtts_wer_log,
+    parse_sim_log,
+    parse_utmos_log,
+    summarize_cloneval_metrics,
+)
+
+
+@dataclass(frozen=True)
+class BenchmarkSpec:
+    name: str
+    test_list: str
+    wer_kind: str
+    transcript_test_list: Optional[str] = None
+    has_similarity: bool = True
+    has_utmos: bool = False
+    seedtts_lang: Optional[str] = None
+
+
+BENCHMARK_SPECS: dict[str, BenchmarkSpec] = {
+    "librispeech_pc": BenchmarkSpec(
+        name="librispeech_pc",
+        test_list="librispeech_pc_test_clean.jsonl",
+        transcript_test_list="librispeech_pc_test_clean_transcript.jsonl",
+        wer_kind="hubert",
+        has_similarity=True,
+        has_utmos=True,
+    ),
+    "seedtts_en": BenchmarkSpec(
+        name="seedtts_en",
+        test_list="seedtts_test_en.jsonl",
