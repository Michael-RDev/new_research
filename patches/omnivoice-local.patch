+    ),
+    "seedtts_zh": BenchmarkSpec(
+        name="seedtts_zh",
+        test_list="seedtts_test_zh.jsonl",
+        wer_kind="seedtts",
+        has_similarity=True,
+        has_utmos=True,
+        seedtts_lang="zh",
+    ),
+    "minimax": BenchmarkSpec(
+        name="minimax",
