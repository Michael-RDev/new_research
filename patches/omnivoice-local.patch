+#!/usr/bin/env bash
+set -euo pipefail
+
+# Example usage:
+#   bash examples/run_benchmark_compare.sh \
+#     /path/to/candidate_checkpoint \
+#     exp/benchmark_compare \
+#     /path/to/cloneval_test_list.jsonl
+#
+# Optional environment overrides:
+#   BASELINE_MODEL=k2-fsa/OmniVoice
+#   BASELINE_LABEL=OmniVoice
+#   CANDIDATE_LABEL=CandidateModel
+#   PREPARE_ASSETS=1
+#   BENCHMARKS="librispeech_pc seedtts_en seedtts_zh minimax fleurs"
+#   FLEURS_PYTHON=/path/to/python
+
+if [ $# -lt 1 ]; then
+  echo "Usage: $0 <candidate_model> [output_dir] [cloneval_test_list]"
+  exit 1
+fi
+
+CANDIDATE_MODEL="${1}"
+OUTPUT_DIR="${2:-exp/benchmark_compare}"
+CLONEVAL_TEST_LIST="${3:-}"
+
+BASELINE_MODEL="${BASELINE_MODEL:-k2-fsa/OmniVoice}"
+BASELINE_INFER_MODULE="${BASELINE_INFER_MODULE:-omnivoice.cli.infer_batch}"
+BASELINE_CLONEVAL_MODULE="${BASELINE_CLONEVAL_MODULE:-omnivoice.eval.cloneval_benchmark}"
+BASELINE_LABEL="${BASELINE_LABEL:-OmniVoice}"
+CANDIDATE_INFER_MODULE="${CANDIDATE_INFER_MODULE:-omnivoice.cli.infer_batch}"
+CANDIDATE_CLONEVAL_MODULE="${CANDIDATE_CLONEVAL_MODULE:-omnivoice.eval.cloneval_benchmark}"
+CANDIDATE_LABEL="${CANDIDATE_LABEL:-CandidateModel}"
+PREPARE_ASSETS="${PREPARE_ASSETS:-0}"
+BENCHMARKS="${BENCHMARKS:-librispeech_pc seedtts_en seedtts_zh minimax fleurs}"
+FLEURS_PYTHON="${FLEURS_PYTHON:-python}"
+PYTHON_BIN="${PYTHON_BIN:-python}"
+
+read -r -a benchmark_args <<< "${BENCHMARKS}"
+
+cmd=(
+  "${PYTHON_BIN}" -m omnivoice.scripts.benchmark_compare
+  --baseline-model "${BASELINE_MODEL}"
+  --candidate-model "${CANDIDATE_MODEL}"
+  --baseline-infer-module "${BASELINE_INFER_MODULE}"
+  --candidate-infer-module "${CANDIDATE_INFER_MODULE}"
+  --baseline-cloneval-module "${BASELINE_CLONEVAL_MODULE}"
+  --candidate-cloneval-module "${CANDIDATE_CLONEVAL_MODULE}"
+  --baseline-label "${BASELINE_LABEL}"
+  --candidate-label "${CANDIDATE_LABEL}"
+  --output-dir "${OUTPUT_DIR}"
+  --fleurs-python "${FLEURS_PYTHON}"
+  --benchmarks "${benchmark_args[@]}"
+)
+
+if [ "${PREPARE_ASSETS}" = "1" ]; then
+  cmd+=(--prepare-assets)
+fi
+
+if [ -n "${CLONEVAL_TEST_LIST}" ]; then
+  cmd+=(--cloneval-test-list "${CLONEVAL_TEST_LIST}")
+fi
+
+"${cmd[@]}"
