+        wer_kind="fleurs",
+        has_similarity=True,
+        has_utmos=False,
+    ),
+}
+
+EVAL_DATA_FILES = [
+    "librispeech_pc_test_clean.jsonl",
+    "librispeech_pc_test_clean_transcript.jsonl",
+    "seedtts_test_en.jsonl",
+    "seedtts_test_zh.jsonl",
+    "minimax_multilingual_24.jsonl",
+    "fleurs_multilingual_102.jsonl",
+]
+
+EVAL_ARCHIVES = [
+    "librispeech_pc_testset.tar.gz",
+    "seedtts_testset.tar.gz",
+    "minimax_multilingual_24.tar.gz",
+    "fleurs_multilingual_102.tar.gz",
+]
+
+
+def _slugify(value: str) -> str:
+    slug = re.sub(r"[^a-zA-Z0-9]+", "_", value.strip().lower()).strip("_")
+    return slug or "model"
+
+
+def _quote(cmd: list[str]) -> str:
+    return shlex.join(cmd)
+
+
+def _run_command(cmd: list[str], cwd: Path, env: dict[str, str]) -> None:
+    logging.info("Running command: %s", _quote(cmd))
+    subprocess.run(cmd, cwd=str(cwd), env=env, check=True)
+
+
+def _repo_env(repo_root: Path) -> dict[str, str]:
+    env = os.environ.copy()
+    current = env.get("PYTHONPATH")
+    python_paths = [str(repo_root)]
+    if repo_root.parent != repo_root:
+        python_paths.append(str(repo_root.parent))
+    if current:
+        python_paths.append(current)
+    env["PYTHONPATH"] = ":".join(python_paths)
+    return env
+
+
+def _default_cloneval_device() -> str:
+    if torch.cuda.is_available():
+        return "cuda:0"
+    if torch.backends.mps.is_available():
+        return "mps"
+    return "cpu"
+
+
+def get_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument(
+        "--baseline-model",
