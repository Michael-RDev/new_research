+        help="Batch size passed to the FLEURS WER script.",
+    )
+    parser.add_argument(
+        "--fleurs-chunk-size",
+        type=int,
+        default=100,
+        help="Chunk size passed to the FLEURS WER script.",
+    )
+    return parser
+
+
+def prepare_eval_assets(
+    repo_root: Path,
+    data_dir: Path,
+    model_dir: Path,
+    env: dict[str, str],
+) -> None:
+    if shutil.which("huggingface-cli") is None:
+        raise RuntimeError(
+            "huggingface-cli is required for --prepare-assets but is not installed."
+        )
+
+    data_dir.mkdir(parents=True, exist_ok=True)
+    model_dir.mkdir(parents=True, exist_ok=True)
+
+    dataset_repo = "k2-fsa/TTS_eval_datasets"
+    for file_name in EVAL_DATA_FILES + EVAL_ARCHIVES:
+        target = data_dir / file_name
+        if target.exists():
+            continue
+        _run_command(
+            [
+                "huggingface-cli",
+                "download",
+                "--repo-type",
+                "dataset",
+                "--local-dir",
+                str(data_dir),
+                dataset_repo,
+                file_name,
+            ],
+            cwd=repo_root,
+            env=env,
+        )
+
+    for archive_name in EVAL_ARCHIVES:
+        archive_path = data_dir / archive_name
+        if not archive_path.exists():
+            continue
+        with tarfile.open(archive_path, "r:gz") as archive:
+            sentinel = next(
+                (
+                    data_dir / member.name
+                    for member in archive.getmembers()
+                    if member.isfile()
+                ),
+                None,
+            )
+            if sentinel is not None and sentinel.exists():
+                continue
+            archive.extractall(path=data_dir)
+
+    sentinel_paths = [
+        model_dir / "speaker_similarity" / "wavlm_large_finetune.pth",
+        model_dir / "mos" / "utmos22_strong_step7459_v1.pt",
+        model_dir / "wer" / "whisper-large-v3",
+    ]
+    if all(path.exists() for path in sentinel_paths):
+        return
+
+    _run_command(
+        [
+            "huggingface-cli",
+            "download",
+            "--local-dir",
+            str(model_dir),
+            "k2-fsa/TTS_eval_models",
+        ],
+        cwd=repo_root,
+        env=env,
+    )
+
+
+def _write_json(path: Path, payload: dict[str, Any]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(json.dumps(payload, indent=2), encoding="utf-8")
+
+
+def _standard_runtime_summary_path(benchmark_dir: Path) -> Path:
+    return benchmark_dir / "runtime_metrics.summary.json"
+
+
+def _standard_runtime_csv_path(benchmark_dir: Path) -> Path:
+    return benchmark_dir / "runtime_metrics.csv"
+
+
