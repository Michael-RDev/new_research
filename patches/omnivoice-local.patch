+    sim = parse_sim_log(logs_dir / "sim.log") if spec.has_similarity else {}
+    utmos = parse_utmos_log(logs_dir / "utmos.log") if spec.has_utmos else {}
+
+    if spec.wer_kind == "hubert":
+        wer = parse_hubert_wer_log(logs_dir / "wer.log")
+    elif spec.wer_kind == "seedtts":
+        wer = parse_seedtts_wer_log(logs_dir / "wer.log")
+    else:
+        wer = parse_multilingual_wer_log(logs_dir / "wer.log")
+
+    summary = {
+        "benchmark": spec.name,
+        "wer_average": wer.get("average"),
+        "wer_weighted": wer.get("weighted"),
+        "wer_macro_average": wer.get("macro_average"),
+        "wer_selected": wer.get("selected"),
+        "sim_average": sim.get("average"),
+        "sim_macro_average": sim.get("macro_average"),
+        "sim_selected": sim.get("selected"),
+        "utmos_average": utmos.get("average"),
+        "utmos_macro_average": utmos.get("macro_average"),
+        "utmos_selected": utmos.get("selected"),
+        "mean_latency_s": runtime.get("mean_latency_s"),
+        "mean_output_duration_s": runtime.get("mean_output_duration_s"),
+        "mean_real_time_factor": runtime.get("mean_real_time_factor"),
+        "max_rss_bytes": runtime.get("max_rss_bytes"),
+        "num_samples": runtime.get("num_samples"),
