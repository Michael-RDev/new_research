new file mode 100644
index 0000000..6f52d80
--- /dev/null
+++ b/omnivoice/eval/benchmark_summary.py
@@ -0,0 +1,190 @@
+#!/usr/bin/env python3
+
+"""Utilities for parsing benchmark outputs into comparable summaries."""
+
+from __future__ import annotations
+
+import csv
+import json
+import re
+from pathlib import Path
+from typing import Any, Iterable, Optional
+
+
+def _read_text(path: Path) -> str:
+    return path.read_text(encoding="utf-8") if path.exists() else ""
+
+
+def _extract_last_float(pattern: str, text: str) -> Optional[float]:
+    matches = re.findall(pattern, text, flags=re.MULTILINE)
+    if not matches:
+        return None
+    return float(matches[-1])
+
+
+def parse_runtime_summary(path: Path) -> dict[str, Any]:
+    if not path.exists():
+        return {}
+    payload = json.loads(path.read_text(encoding="utf-8"))
+    return {
+        "num_samples": payload.get("num_samples"),
+        "mean_latency_s": payload.get("mean_latency_s"),
+        "mean_output_duration_s": payload.get("mean_output_duration_s"),
+        "mean_real_time_factor": payload.get("mean_real_time_factor"),
+        "max_rss_bytes": payload.get("max_peak_rss_bytes", payload.get("max_rss_bytes")),
+        "total_audio_duration_s": payload.get("total_audio_duration_s"),
+        "total_synthesis_time_s": payload.get("total_synthesis_time_s"),
+    }
+
+
+def parse_sim_log(path: Path) -> dict[str, Optional[float]]:
+    text = _read_text(path)
+    average = _extract_last_float(r"Average SIM-o:\s*([0-9.]+)", text)
+    macro_average = _extract_last_float(
+        r"Macro-average SIM-o over \d+ languages:\s*([0-9.]+)", text
+    )
+    return {
+        "average": average,
+        "macro_average": macro_average,
+        "selected": macro_average if macro_average is not None else average,
+    }
+
+
+def parse_utmos_log(path: Path) -> dict[str, Optional[float]]:
+    text = _read_text(path)
+    average = _extract_last_float(r"Average UTMOS:\s*([0-9.]+)", text)
+    macro_average = _extract_last_float(
+        r"Macro-average UTMOS over \d+ languages:\s*([0-9.]+)", text
+    )
+    return {
+        "average": average,
+        "macro_average": macro_average,
+        "selected": macro_average if macro_average is not None else average,
+    }
+
+
+def parse_hubert_wer_log(path: Path) -> dict[str, Optional[float]]:
+    text = _read_text(path)
+    weighted = _extract_last_float(r"WER:\s*([0-9.]+)%", text)
+    return {
+        "average": None,
+        "weighted": weighted,
+        "macro_average": None,
+        "selected": weighted,
+    }
+
+
+def parse_seedtts_wer_log(path: Path) -> dict[str, Optional[float]]:
+    text = _read_text(path)
+    average = _extract_last_float(
+        r"Seed-TTS WER \(Avg of WERs\):\s*([0-9.]+)%", text
+    )
+    weighted = _extract_last_float(r"WER \(Weighted\):\s*([0-9.]+)%", text)
+    return {
+        "average": average,
+        "weighted": weighted,
+        "macro_average": None,
+        "selected": weighted if weighted is not None else average,
+    }
+
+
+def parse_multilingual_wer_log(path: Path) -> dict[str, Optional[float]]:
+    text = _read_text(path)
+    macro_average = _extract_last_float(
+        r"Macro-average WER over \d+ languages:\s*([0-9.]+)%", text
+    )
+    overall = _extract_last_float(r"Overall WER:\s*([0-9.]+)%", text)
+    return {
+        "average": None,
+        "weighted": overall,
+        "macro_average": macro_average,
+        "selected": macro_average if macro_average is not None else overall,
+    }
+
+
+def _mean(values: Iterable[float]) -> Optional[float]:
+    values = list(values)
+    if not values:
+        return None
+    return sum(values) / len(values)
+
+
+def summarize_cloneval_metrics(metrics_dir: Path) -> dict[str, Any]:
+    aggregated_path = metrics_dir / "aggregated_results.csv"
+    runtime_summary = parse_runtime_summary(metrics_dir / "runtime_metrics.summary.json")
+
+    rows: list[dict[str, str]] = []
+    if aggregated_path.exists():
+        with aggregated_path.open("r", encoding="utf-8", newline="") as f:
+            rows = list(csv.DictReader(f))
+
+    def _column_mean(name: str) -> Optional[float]:
+        values = []
+        for row in rows:
+            value = row.get(name)
+            if value in (None, ""):
+                continue
+            values.append(float(value))
+        return _mean(values)
+
+    metrics = {
+        "speaker_similarity": _column_mean("speaker_similarity"),
+        "intelligibility": _column_mean("intelligibility"),
+        "naturalness": _column_mean("naturalness"),
+        "emotion_transfer": _column_mean("emotion_transfer"),
+    }
+    metrics.update(runtime_summary)
+    return metrics
+
+
+def benchmark_primary_metrics(benchmark: str) -> list[tuple[str, str]]:
+    mapping = {
+        "librispeech_pc": [
+            ("wer_selected", "lower"),
+            ("sim_selected", "higher"),
+            ("utmos_selected", "higher"),
+        ],
+        "seedtts_en": [
+            ("wer_selected", "lower"),
+            ("sim_selected", "higher"),
+            ("utmos_selected", "higher"),
+        ],
+        "seedtts_zh": [
+            ("wer_selected", "lower"),
+            ("sim_selected", "higher"),
+            ("utmos_selected", "higher"),
+        ],
+        "minimax": [
+            ("wer_selected", "lower"),
+            ("sim_selected", "higher"),
+        ],
+        "fleurs": [
+            ("wer_selected", "lower"),
+            ("sim_selected", "higher"),
+        ],
+        "cloneval": [
+            ("speaker_similarity", "higher"),
+        ],
+    }
+    return mapping.get(benchmark, [])
+
+
+def choose_winner(
+    baseline_value: Optional[float],
+    candidate_value: Optional[float],
+    direction: str,
+) -> str:
+    if baseline_value is None or candidate_value is None:
+        return "n/a"
+    if baseline_value == candidate_value:
+        return "tie"
+    if direction == "higher":
+        return "candidate" if candidate_value > baseline_value else "baseline"
+    return "candidate" if candidate_value < baseline_value else "baseline"
+
+
+def format_metric(value: Optional[float], digits: int = 4) -> str:
+    if value is None:
+        return "n/a"
+    return f"{value:.{digits}f}"
+
