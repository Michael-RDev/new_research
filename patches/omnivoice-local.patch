+    recipes: list[CorpusRecipe] = []
+    if stage in {"stage1", "all"}:
+        recipes.extend(_stage1_recipes(profile))
+    if stage in {"stage2", "all"}:
+        recipes.extend(_stage2_recipes(profile))
+    return recipes
