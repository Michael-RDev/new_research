+#!/usr/bin/env python3
+
+"""Aoede conditioning modules.
+
+This module is the public name for the speaker-memory and prosody-plan
+conditioning stack that was prototyped under the internal MnemosVoice codename.
+The legacy module path remains available for older checkpoints and scripts.
+"""
+
+from omnivoice.models.mnemosvoice import (  # noqa: F401
+    MemoryConditioner,
+    ProsodyPlanAdapter,
+    SpeakerMemoryEncoder,
+)
