diff --git a/tests/test_benchmark_summary.py b/tests/test_benchmark_summary.py
new file mode 100644
index 0000000..b794376
--- /dev/null
+++ b/tests/test_benchmark_summary.py
@@ -0,0 +1,117 @@
+from pathlib import Path
+
+from omnivoice.eval.benchmark_summary import (
+    choose_winner,
+    parse_hubert_wer_log,
+    parse_multilingual_wer_log,
+    parse_runtime_summary,
+    parse_seedtts_wer_log,
+    parse_sim_log,
+    parse_utmos_log,
+    summarize_cloneval_metrics,
+)
+from omnivoice.scripts.benchmark_compare import get_parser
+
+
+def test_parse_sim_and_utmos_logs(tmp_path: Path):
+    sim_log = tmp_path / "sim.log"
+    sim_log.write_text(
+        "[English] SIM-o: 0.700 (10 pairs)\n"
+        "Macro-average SIM-o over 2 languages: 0.765\n"
+        "Average SIM-o: 0.742\n",
+        encoding="utf-8",
+    )
+    utmos_log = tmp_path / "utmos.log"
+    utmos_log.write_text(
+        "[English] UTMOS: 4.12 (10 samples)\n"
+        "Macro-average UTMOS over 2 languages: 4.08\n"
+        "Average UTMOS: 4.15\n",
+        encoding="utf-8",
+    )
+
+    sim = parse_sim_log(sim_log)
+    utmos = parse_utmos_log(utmos_log)
+
+    assert sim["average"] == 0.742
+    assert sim["macro_average"] == 0.765
+    assert sim["selected"] == 0.765
+    assert utmos["average"] == 4.15
+    assert utmos["macro_average"] == 4.08
+    assert utmos["selected"] == 4.08
+
+
+def test_parse_wer_logs(tmp_path: Path):
+    hubert_log = tmp_path / "hubert.log"
+    hubert_log.write_text("WER: 1.30%\n", encoding="utf-8")
+    seedtts_log = tmp_path / "seedtts.log"
+    seedtts_log.write_text(
+        "Seed-TTS WER (Avg of WERs): 1.62%\nWER (Weighted): 1.57%\n",
+        encoding="utf-8",
+    )
+    multilingual_log = tmp_path / "minimax.log"
+    multilingual_log.write_text(
+        "[French] WER: 3.20%\n"
+        "Macro-average WER over 24 languages: 2.85%\n"
+        "Overall WER: 2.91%\n",
+        encoding="utf-8",
+    )
+
+    hubert = parse_hubert_wer_log(hubert_log)
+    seedtts = parse_seedtts_wer_log(seedtts_log)
+    multilingual = parse_multilingual_wer_log(multilingual_log)
+
+    assert hubert["selected"] == 1.30
+    assert seedtts["average"] == 1.62
+    assert seedtts["weighted"] == 1.57
+    assert seedtts["selected"] == 1.57
+    assert multilingual["macro_average"] == 2.85
+    assert multilingual["weighted"] == 2.91
+    assert multilingual["selected"] == 2.85
+
+
+def test_parse_runtime_and_cloneval_summary(tmp_path: Path):
+    runtime_summary = tmp_path / "runtime_metrics.summary.json"
+    runtime_summary.write_text(
+        (
+            "{\n"
+            '  "num_samples": 2,\n'
+            '  "mean_latency_s": 0.5,\n'
+            '  "mean_output_duration_s": 2.0,\n'
+            '  "mean_real_time_factor": 0.25,\n'
+            '  "max_peak_rss_bytes": 12345\n'
+            "}\n"
+        ),
+        encoding="utf-8",
+    )
+    aggregated = tmp_path / "aggregated_results.csv"
+    aggregated.write_text(
+        "speaker_similarity,intelligibility,naturalness,emotion_transfer\n"
+        "0.8,0.7,0.6,0.5\n"
+        "0.6,0.9,0.8,0.4\n",
+        encoding="utf-8",
+    )
+
+    runtime = parse_runtime_summary(runtime_summary)
+    cloneval = summarize_cloneval_metrics(tmp_path)
+
+    assert runtime["max_rss_bytes"] == 12345
+    assert cloneval["speaker_similarity"] == 0.7
+    assert cloneval["intelligibility"] == 0.8
+    assert cloneval["naturalness"] == 0.7
+    assert cloneval["emotion_transfer"] == 0.45
+    assert cloneval["mean_real_time_factor"] == 0.25
+
+
+def test_choose_winner_respects_metric_direction():
+    assert choose_winner(1.5, 1.2, "lower") == "candidate"
+    assert choose_winner(0.8, 0.9, "higher") == "candidate"
+    assert choose_winner(0.8, 0.8, "higher") == "tie"
+    assert choose_winner(None, 0.8, "higher") == "n/a"
+
+
+def test_benchmark_compare_defaults_match_repo_download_layout():
+    parser = get_parser()
+    args = parser.parse_args(["--candidate-model", "candidate"])
+
+    assert args.eval_data_dir == "download/tts_eval_datasets"
+    assert args.eval_model_dir == "download/tts_eval_models"
