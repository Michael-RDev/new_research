+            "total_audio_duration_s": round(total_audio_duration, 4),
+            "total_synthesis_time_s": round(total_synthesis_time, 4),
+            "mean_latency_s": round(
+                sum(row["latency_s"] for row in runtime_rows) / len(runtime_rows), 4
+            )
+            if runtime_rows
+            else 0.0,
+            "mean_output_duration_s": round(
+                sum(row["output_duration_s"] for row in runtime_rows)
+                / len(runtime_rows),
+                4,
+            )
+            if runtime_rows
+            else 0.0,
+            "mean_real_time_factor": round(average_rtf, 4)
+            if average_rtf is not None
+            else None,
+            "max_peak_rss_bytes": max(
+                (row["peak_rss_bytes"] for row in runtime_rows),
+                default=0,
+            ),
+        }
+        summary_path.write_text(json.dumps(summary, indent=2), encoding="utf-8")
+        logging.info(f"Saved aggregate runtime metrics to {summary_path}")
+
     logging.info("Done!")
 
 
